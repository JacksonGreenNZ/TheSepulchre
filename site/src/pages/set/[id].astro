---
import Base from "../../layouts/Base.astro";
import data from "../../data/content.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p) => `${base}${p}`;

export async function getStaticPaths() {
  const d = (await import("../../data/content.json")).default;
  return d.sets.map((s) => ({ params: { id: s.id }, props: { set: s } }));
}

const { set } = Astro.props;

// other sets replacing the same domain(s) = alternatives that conflict
const conflicts = data.sets.filter(
  (s) => s.id !== set.id && s.replaces.some((d) => set.replaces.includes(d))
);
---

<Base title={set.title}>
  <p class="muted"><a href={link(`/${set.category}/`)}>← {set.category}</a></p>
  <h1>{set.title}</h1>
  <div class="muted">by {set.author} · v{set.version} · {set.license}</div>
  <div style="margin:.5rem 0;">{set.tags.map((t) => <span class="tag">{t}</span>)}</div>

  <div class="card">
    <strong>Compatibility</strong>
    <div>Replaces: {set.replaces.length ? set.replaces.join(", ") : "nothing"}</div>
    <div>Requires: {set.requires.length ? set.requires.join(", ") : "nothing"}</div>
    {conflicts.length > 0 && (
      <div class="conflict" style="margin-top:.4rem;">
        Do not combine with:{" "}
        {conflicts.map((c, i) => (
          <>{i > 0 && ", "}<a href={link(`/set/${c.id}/`)}>{c.title}</a></>
        ))}
      </div>
    )}
  </div>

  {set.files.map((f) => (
    <div class="card">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:.5rem;">
        <strong>{f.name}</strong>
        <a href={link(f.url)} download>Download</a>
      </div>
      <iframe class="pdf" src={link(f.url)} title={f.name}></iframe>
    </div>
  ))}

  <div class="card prose" set:html={set.readmeHtml}></div>
</Base>
